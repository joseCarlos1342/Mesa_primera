# Variables de entorno — Mesa Primera
# Copia este archivo como .env.local y completa con tus valores reales.
# NUNCA commitees archivos .env con valores reales.

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Game Server ===
GAME_SERVER_PORT=2567
GAME_SERVER_URL=http://localhost:2567
NEXT_PUBLIC_GAME_SERVER_URL=https://vps23830.cubepath.net
NEXT_PUBLIC_SOCKET_URL=https://vps23830.cubepath.net
INTERNAL_API_SECRET=cambia-este-secreto-en-produccion

# === Twilio Verify (OTP SMS) ===
TWILIO_ACCOUNT_SID=AC...tu-account-sid-aqui
TWILIO_AUTH_TOKEN=tu-auth-token-de-console.twilio.com
TWILIO_VERIFY_SERVICE_SID=VA...tu-service-sid-aqui

# === Google OAuth ===
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-google-client-secret
# Para desarrollo local de Supabase:
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=tu-google-client-secret

# === LiveKit ===
# LIVEKIT_URL=wss://tu-proyecto.livekit.cloud
# LIVEKIT_API_KEY=tu-api-key
# LIVEKIT_API_SECRET=tu-api-secret
