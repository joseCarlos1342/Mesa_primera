# Variables de entorno — Mesa Primera
# Copia este archivo como .env.local y completa con tus valores reales.
# NUNCA commitees archivos .env con valores reales.

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Game Server ===
GAME_SERVER_PORT=2567
GAME_SERVER_URL=http://localhost:2567

# === Twilio (OTP SMS) ===
# TWILIO_ACCOUNT_SID=tu-account-sid
# TWILIO_AUTH_TOKEN=tu-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# === LiveKit ===
# LIVEKIT_URL=wss://tu-proyecto.livekit.cloud
# LIVEKIT_API_KEY=tu-api-key
# LIVEKIT_API_SECRET=tu-api-secret
